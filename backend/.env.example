PORT=3001
NODE_ENV=development

# Supabase — get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-secret-key-here
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=eyJ...

# JWT secret — make this long and random in production
JWT_SECRET=change-this-to-something-very-secret
JWT_EXPIRES_IN=7d

CORS_ORIGIN=*
